        },
        {
          "character": "你",
          "emotion": "thinking",
          "text": "（该做点什么好呢……）",
          "choices": [
            { "text": "整理货架", "nextSceneId": "branch_shelf" },
            { "text": "继续摸鱼玩手机", "nextSceneId": "branch_phone" },
            { "text": "检查关东煮", "nextSceneId": "branch_oden" }
          ]
        }
      ]
    },
    {
      "id": "branch_shelf",
      "background": "shelf_area.png",
